# =====================================================================
# JLPT Kanji App — Environment Variables
# ---------------------------------------------------------------------
# Copy this file to `.env` and fill in the values you need.
#   cp .env.example .env
#
# Only ANTHROPIC_API_KEY is required for quiz generation.
# Everything else is optional and has sensible defaults.
# =====================================================================

# --- REQUIRED (for AI quiz generation) -------------------------------
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- OPTIONAL --------------------------------------------------------
# Claude model used to generate quizzes.
# Default: claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# API server host & port.
# Default host: 127.0.0.1
# Default port: 8787
HOST=127.0.0.1
PORT=8787

# Allowed origin for CORS (where the Vite dev server runs).
# Default: http://127.0.0.1:5173
APP_ORIGIN=http://127.0.0.1:5173
